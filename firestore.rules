rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to reference data (games, colleges, sponsorship_tiers)
    match /games/{document} {
      allow read: if true;
      allow write: if false;
    }
    
    match /colleges/{document} {
      allow read: if true;
      allow write: if false;
    }
    
    match /sponsorship_tiers/{document} {
      allow read: if true;
      allow write: if false;
    }
    
    // Allow read/write for registrations
    match /team_registrations/{document} {
      allow read, write: if true;
    }
    
    match /sponsor_registrations/{document} {
      allow read, write: if true;
    }
    
    match /visitor_registrations/{document} {
      allow read, write: if true;
    }
    
    match /media_registrations/{document} {
      allow read, write: if true;
    }
  }
}
